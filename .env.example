# Copy this file to .env and fill in real values. Never commit .env.

# --- Postgres ---
POSTGRES_USER=lifeos
POSTGRES_PASSWORD=changeme
POSTGRES_DB=lifeos
DATABASE_URL=postgresql+psycopg://lifeos:changeme@postgres:5432/lifeos

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- Telegram ---
# Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=
# Your numeric Telegram user id (get from @userinfobot). Leave blank in early dev
# to accept messages from anyone; set it to lock the bot to you only.
TELEGRAM_ALLOWED_USER_ID=

# --- n8n ---
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=changeme

# --- Cloudflare Tunnel (fill in once you've created a tunnel in the Cloudflare
# Zero Trust dashboard; see README for steps). Not required for local dev. ---
CLOUDFLARE_TUNNEL_TOKEN=

# --- Local LLM (Ollama on host, via host.docker.internal from inside containers) ---
OLLAMA_BASE_URL=http://host.docker.internal:11434

# --- Cloud LLM (not used yet, Week 4+) ---
OPENROUTER_API_KEY=
