# Copy this file to .env and fill in real values. Never commit .env.

# --- Postgres ---
POSTGRES_USER=lifeos
POSTGRES_PASSWORD=changeme
POSTGRES_DB=lifeos
DATABASE_URL=postgresql+psycopg://lifeos:changeme@postgres:5432/lifeos

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- Telegram ---
# Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=
# Your numeric Telegram user id (get from @userinfobot). Leave blank in early dev
# to accept messages from anyone; set it to lock the bot to you only.
TELEGRAM_ALLOWED_USER_ID=

# --- n8n ---
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=changeme

# --- ngrok tunnel (free static domain, no Cloudflare account needed) ---
# Get authtoken from https://dashboard.ngrok.com, reserve a free static
# domain there too.
NGROK_AUTHTOKEN=
NGROK_STATIC_DOMAIN=

# --- Local LLM (Ollama on host, via host.docker.internal from inside containers) ---
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=qwen3.6:35b-a3b

# --- Cloud LLM (not used yet, Week 4+) ---
OPENROUTER_API_KEY=

# --- Google Maps (driving directions + train departures) ---
# Cloud Console project with Directions API enabled. Free tier ($200/mo credit)
# comfortably covers personal use.
GOOGLE_MAPS_API_KEY=

# --- Google Calendar (OAuth "Desktop app" client, see README) ---
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=
GOOGLE_CALENDAR_REFRESH_TOKEN=

# --- Apple Health sync (Health Auto Export app, see README) ---
# Random long string of your choosing; the iOS app must send it back as
# "Authorization: Bearer <this value>" on every export, since this endpoint
# is otherwise reachable through the public ngrok tunnel like everything else.
HEALTH_SYNC_TOKEN=
